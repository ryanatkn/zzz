#!/usr/bin/env bash

# Hex - GPU-Accelerated 2D Action RPG
# Simple development wrapper around 'zig build run'

set -e

# Change to script directory
cd "$( dirname "${BASH_SOURCE[0]}" )"

# Colors for output
readonly GREEN='\033[0;32m'
readonly NC='\033[0m'

# Function to print colored output
print_color() {
    echo -e "${2}${1}${NC}"
}

# Check for help
if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
    echo "hex - GPU-Accelerated 2D Action RPG"
    echo ""
    echo "Usage: ./hex [game-args...]"
    echo ""
    echo "This is a simple wrapper around 'zig build run'."
    echo "Shaders are compiled automatically as part of the build."
    echo ""
    echo "For more build options:"
    echo "  zig build --help           Show all build options"
    echo "  zig build                  Build (includes shader compilation)"
    echo "  zig build run              Build and run"
    echo "  zig build shaders          Compile shaders only"
    echo "  zig build clean-shaders    Clean and rebuild shaders"
    echo ""
    echo "Cross-compilation examples:"
    echo "  zig build -Dtarget=x86_64-windows -Doptimize=ReleaseFast"
    echo "  zig build -Doptimize=ReleaseFast"
    echo ""
    echo "Game Controls:"
    echo "  Mouse/WASD        Movement"
    echo "  Right Click       Fire projectile"
    echo "  Space            Pause"
    echo "  R                Respawn"
    echo "  ESC              Quit"
    exit 0
fi

# Run the game
print_color "starting hex..." "$GREEN"
exec zig build run -- "$@"