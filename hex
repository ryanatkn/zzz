#!/usr/bin/env bash

# Hex - GPU-Accelerated 2D Action RPG
# Build wrapper script that auto-compiles shaders and builds before running

set -e

# Configuration
readonly SCRIPT_DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" && pwd )"
readonly SHADER_SCRIPT="src/shaders/compile_shaders.sh"
readonly BUILD_TARGET="zig-out/bin/hex"

# Colors for output
readonly RED='\033[0;31m'
readonly GREEN='\033[0;32m'
readonly YELLOW='\033[1;33m'
readonly NC='\033[0m'

# Change to script directory
cd "$SCRIPT_DIR"

# Function to print colored output
print_color() {
    echo -e "${2}${1}${NC}"
}

# Function to compile shaders
compile_shaders() {
    if [[ -f "$SHADER_SCRIPT" ]]; then
        print_color "🎨 Compiling shaders..." "$YELLOW"
        if bash "$SHADER_SCRIPT"; then
            print_color "✅ Shaders compiled successfully" "$GREEN"
        else
            print_color "❌ Shader compilation failed" "$RED"
            exit 1
        fi
    else
        print_color "⚠️  No shader compilation script found, skipping..." "$YELLOW"
    fi
}

# Function to build the game
build_game() {
    print_color "🔨 Building hex..." "$YELLOW"
    if zig build -Doptimize=ReleaseFast; then
        print_color "✅ Build successful" "$GREEN"
    else
        print_color "❌ Build failed" "$RED"
        exit 1
    fi
}

# Function to run the game
run_game() {
    print_color "🎮 Starting hex..." "$GREEN"
    exec "./$BUILD_TARGET" "$@"
}

# Main execution flow
main() {
    # Check if zig is installed
    if ! command -v zig &> /dev/null; then
        print_color "❌ Error: zig is not installed or not in PATH" "$RED"
        print_color "Please install Zig 0.14.1 or newer" "$YELLOW"
        exit 1
    fi

    # Check first argument for special cases
    case "${1:-}" in
        windows)
            print_color "🪟 Building for Windows x86_64 (ReleaseFast)..." "$YELLOW"
            compile_shaders
            if zig build -Dtarget=x86_64-windows -Doptimize=ReleaseFast; then
                # Rename with today's date
                local date_str=$(date +%b_%d_%Y | tr '[:upper:]' '[:lower:]')
                mv "./zig-out/bin/hex.exe" "./zig-out/bin/hex_${date_str}.exe"
                print_color "✅ Windows build complete: zig-out/bin/hex_${date_str}.exe" "$GREEN"
            else
                print_color "❌ Windows build failed!" "$RED"
                exit 1
            fi
            exit 0
            ;;
        --help|-h)
            echo "hex - GPU-Accelerated 2D Action RPG"
            echo ""
            echo "Usage: ./hex [options]"
            echo ""
            echo "Special commands:"
            echo "  windows           Build for Windows x86_64 with date suffix"
            echo ""
            echo "Options:"
            echo "  --help, -h        Show this help message"
            echo "  --clean-shaders   Clean and rebuild all shaders"
            echo "  --skip-shaders    Skip shader compilation"
            echo "  --debug           Build with debug symbols"
            echo ""
            echo "Controls:"
            echo "  Mouse/WASD        Movement"
            echo "  Right Click       Fire projectile"
            echo "  Space            Pause"
            echo "  R                Respawn"
            echo "  ESC              Quit"
            exit 0
            ;;
    esac

    # Handle remaining flags (skip first arg if it was a special command)
    local skip_shaders=false
    local debug_build=false
    local clean_shaders=false
    local game_args=()

    # Filter out the special commands from argument processing
    local args_to_process=("$@")

    for arg in "${args_to_process[@]}"; do
        case $arg in
            --skip-shaders)
                skip_shaders=true
                ;;
            --debug)
                debug_build=true
                ;;
            --clean-shaders)
                clean_shaders=true
                ;;
            *)
                game_args+=("$arg")
                ;;
        esac
    done

    # Clean shaders if requested
    if [[ "$clean_shaders" == true ]]; then
        print_color "🧹 Cleaning shaders..." "$YELLOW"
        if [[ -f "$SHADER_SCRIPT" ]]; then
            bash "$SHADER_SCRIPT" --clean
        fi
    fi

    # Compile shaders (unless skipped)
    if [[ "$skip_shaders" == false ]]; then
        compile_shaders
    fi

    # Build the game
    if [[ "$debug_build" == true ]]; then
        print_color "🔨 Building hex (debug mode)..." "$YELLOW"
        if zig build -Doptimize=Debug; then
            print_color "✅ Debug build successful" "$GREEN"
        else
            print_color "❌ Build failed" "$RED"
            exit 1
        fi
    else
        build_game
    fi

    # Run the game with any remaining arguments
    run_game "${game_args[@]}"
}

# Run main function with all arguments
main "$@"